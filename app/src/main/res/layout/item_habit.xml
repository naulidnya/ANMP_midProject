<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ROW 1 : ICON + TITLE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgHabit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/baseline_water_drop_24"
                tools:ignore="ContentDescription"/>

            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Drink Water"/>
        </LinearLayout>

        <!-- ROW 2 : DESCRIPTION -->
        <TextView
            android:id="@+id/txtDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="14sp"
            android:textColor="#555555"
            tools:text="Stay hydrated throughout the day"/>

        <!-- ROW 3 : PROGRESS LABEL + CHECK ICON -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Progress"
                android:textStyle="bold"/>

            <ImageView
                android:id="@+id/imgStatus"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="6dp"
                android:visibility="gone"
                android:src="@drawable/baseline_check_circle_24"
                tools:ignore="ContentDescription"/>
        </LinearLayout>

        <!-- ROW 4 : PROGRESS BAR + TEXT (SIDE BY SIDE) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_weight="1"
                android:progressTint="#6200EE"
                android:backgroundTint="#E0E0E0"
                tools:progress="3"/>

            <TextView
                android:id="@+id/txtProgressNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textStyle="bold"
                tools:text="3/8 glasses"/>
        </LinearLayout>

        <!-- ROW 5 : BUTTON -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- MINUS -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMinus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="−"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:backgroundTint="#E0E0E0"
                app:cornerRadius="24dp"/>

            <!-- PLUS -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:text="+"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#6200EE"
                app:cornerRadius="24dp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>